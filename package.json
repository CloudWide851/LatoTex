{
  "name": "latotex",
  "version": "0.1.1",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-share-page.mjs && node scripts/ensure-share-web-assets.mjs && vite --host 0.0.0.0 --port 1420",
    "build": "node scripts/build-share-page.mjs && node scripts/ensure-share-web-assets.mjs && tsc && vite build && node scripts/copy-public-assets.mjs",
    "build:share-page": "node scripts/build-share-page.mjs",
    "typecheck": "tsc --noEmit",
    "stitch:init": "pnpm exec stitch-mcp init --client codex --transport stdio",
    "stitch:doctor": "pnpm exec stitch-mcp doctor",
    "stitch:proxy": "pnpm exec stitch-mcp proxy",
    "stitch:view": "pnpm exec stitch-mcp view",
    "stitch:serve": "pnpm exec stitch-mcp serve",
    "stitch:site": "pnpm exec stitch-mcp site",
    "arch:check": "node scripts/check-architecture.mjs && node scripts/check-source-size.mjs && node scripts/check-package-scripts.mjs",
    "test:unit": "vitest run",
    "test:e2e": "pnpm build && playwright test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "perf:baseline": "node scripts/perf-baseline.mjs",
    "latotex:mcp": "node scripts/latotex-mcp.mjs",
    "research:eval": "node scripts/research-eval.mjs",
    "security:scan": "node scripts/release-security-scan.mjs",
    "sbom:generate": "node scripts/generate-sbom.mjs",
    "release:hash:win-x64": "node scripts/hash-windows-installer.mjs",
    "release:build-installer:win-x64": "node scripts/package-win-x64.mjs",
    "release:install-smoke:win-x64": "node scripts/install-smoke-win-x64.mjs",
    "release:validate:win-x64": "node scripts/release-check-win-x64.mjs --mode=validate",
    "release:package:win-x64": "node scripts/release-check-win-x64.mjs --mode=package",
    "release:check:win-x64": "node scripts/release-check-win-x64.mjs --mode=check",
    "preview": "vite preview",
    "brand:sync": "node scripts/sync-brand-assets.mjs",
    "brand:icons": "node scripts/ensure-brand-icons.mjs --force",
    "soak:6h-sim": "node scripts/soak-6h-sim.mjs",
    "soak:matrix": "node scripts/soak-6h-sim.mjs --profile=ci-matrix",
    "soak:matrix:full": "node scripts/soak-6h-sim.mjs --profile=full-matrix --minutes=360 --tickMs=1000",
    "audit:debt": "node scripts/audit-historical-debt.mjs",
    "tauri": "node scripts/ensure-brand-icons.mjs && tauri",
    "tauri:build:win-x64": "pnpm tauri build --target x86_64-pc-windows-msvc --bundles nsis",
    "tauri:smoke:win-x64": "node scripts/tauri-smoke-win-x64.mjs"
  },
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "monaco-editor": "^0.55.1",
    "@picocss/pico": "^2.1.1",
    "@tauri-apps/api": "^2.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "lucide-react": "^0.542.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "4.8.69",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "yaml": "^2.4.2",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@_davideast/stitch-mcp": "^0.5.3",
    "@playwright/test": "^1.57.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
