{
  "name": "latotex",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-share-page.mjs && node scripts/ensure-share-web-assets.mjs && node scripts/ensure-drawio-assets.mjs && node scripts/ensure-cloudflared-assets.mjs && vite --host 0.0.0.0 --port 1420",
    "build": "node scripts/build-share-page.mjs && node scripts/ensure-share-web-assets.mjs && node scripts/ensure-drawio-assets.mjs && node scripts/ensure-tectonic-assets.mjs && node scripts/ensure-pdf-tools.mjs && node scripts/ensure-cloudflared-assets.mjs && tsc && vite build && node scripts/copy-public-assets.mjs",
    "build:share-page": "node scripts/build-share-page.mjs",
    "typecheck": "tsc --noEmit",
    "stitch:init": "pnpm exec stitch-mcp init --client codex --transport stdio",
    "stitch:doctor": "pnpm exec stitch-mcp doctor",
    "stitch:proxy": "pnpm exec stitch-mcp proxy",
    "stitch:view": "pnpm exec stitch-mcp view",
    "stitch:serve": "pnpm exec stitch-mcp serve",
    "stitch:site": "pnpm exec stitch-mcp site",
    "arch:check": "node scripts/check-architecture.mjs",
    "test:unit": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "brand:sync": "node scripts/sync-brand-assets.mjs",
    "brand:icons": "node scripts/ensure-brand-icons.mjs --force",
    "soak:6h-sim": "node scripts/soak-6h-sim.mjs",
    "audit:debt": "node scripts/audit-historical-debt.mjs",
    "tauri": "node scripts/ensure-brand-icons.mjs && tauri",
    "pdf-tools:assets": "node scripts/ensure-pdf-tools.mjs"
  },
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@picocss/pico": "^2.1.1",
    "@tauri-apps/api": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "lucide-react": "^0.542.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "4.8.69",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "yaml": "^2.4.2",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@_davideast/stitch-mcp": "^0.5.3",
    "@tauri-apps/cli": "^2.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
