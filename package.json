{
  "name": "latotex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420",
    "build": "node scripts/ensure-busytex-assets.mjs && tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "brand:sync": "node scripts/sync-brand-assets.mjs",
    "brand:icons": "node scripts/ensure-brand-icons.mjs --force",
    "busytex:check": "node scripts/check-busytex-assets.mjs",
    "busytex:assets": "pnpm exec texlyre-busytex download-assets ./public/core",
    "tauri": "node scripts/ensure-brand-icons.mjs && tauri"
  },
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.25",
    "lucide-react": "^0.542.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "4.8.69",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^9.2.1",
    "react-resizable-panels": "^2.1.7",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.3.1",
    "texlyre-busytex": "^0.1.2-alpha",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
